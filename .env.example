# Vercel 배포 시 환경변수 (Settings → Environment Variables)

# 필수 — 관리자 로그인 비밀번호 (admin.html)
ADMIN_PASSWORD=your-admin-password-here

# 필수 — 주문 API 검증 키 (/api/config, /api/orders)
ORDER_SECRET=your-order-secret-here

# 필수 — Vercel Storage → KV 연결 시 자동 주입됨
KV_REST_API_URL=
KV_REST_API_TOKEN=

# 로컬 개발용 (선택)
# PORT=3456
