# Vercel 배포 시 환경변수 (Settings → Environment Variables)

# 필수 — 관리자 로그인 비밀번호 (admin.html)
ADMIN_PASSWORD=your-admin-password-here

# 필수 — 주문 API 검증 키 (/api/config, /api/orders)
ORDER_SECRET=your-order-secret-here

# 필수 — Upstash Redis 연결 시 자동 주입 (아래 방법 참고)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# 또는
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
